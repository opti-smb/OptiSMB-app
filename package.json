{
  "name": "smb-acquirer-portal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:webpack": "next dev -p 3001 --webpack",
    "parser": "npm run start --prefix services",
    "dev:full": "concurrently -n parser,web -c blue,green \"npm run parser\" \"npm run dev\"",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "prisma validate",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio --port 5560",
    "db:wipe": "dotenv -e .env -- node scripts/wipe-app-data.mjs",
    "db:validate": "prisma validate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.4.47",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "typescript": "6.0.3"
  }
}
