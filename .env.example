# Copy to `.env.local` for development (never commit secrets).

# --- PostgreSQL (Prisma in this app; canonical DDL in opti-smb/services db/schema.sql) ---
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/optismb

# --- Server session + encryption at rest (required when DATABASE_URL is set) ---
# Used to sign the HTTP-only session cookie and derive AES key if APP_DATA_ENCRYPTION_KEY is unset.
# SESSION_SECRET=generate-a-long-random-string
# Or: APP_ENCRYPTION_SECRET=... (same fallback as SESSION_SECRET in code)

# Optional: 64 hex chars (32 bytes) for AES-256-GCM; otherwise key is SHA-256 of SESSION_SECRET.
# APP_DATA_ENCRYPTION_KEY=

# --- Statement parser (FastAPI) — local full stack ---
# Default when unset: http://127.0.0.1:8000 (matches `npm run parser` / `npm run dev:full`).
# STATEMENT_PARSER_URL=http://127.0.0.1:8000

# --- Production (Vercel): set to your deployed parser ---
# Public HTTPS base URL of the FastAPI service (`services/app.py` in opti-smb/services), no trailing slash.
# `/api/parse` forwards uploads from the Next server (not the browser).
#
# Example: https://your-parser.onrender.com
STATEMENT_PARSER_URL=

# Optional: long parses need enough serverless duration. This repo sets maxDuration=120 on
# `app/api/parse/route.js`. Vercel Hobby limits functions to 10s; Pro supports higher limits.

# --- Linked merge fee debug (`mergeLinkedStatementUploads`) ---
# DEBUG_FEES=true
# NEXT_PUBLIC_DEBUG_FEES=true
