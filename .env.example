# Copy to `.env.local` for development (never commit secrets).

# --- Production (Vercel): required for real statement parsing ---
# Public HTTPS base URL of your deployed FastAPI service (`python/app.py`), no trailing slash.
# The Next.js route `/api/parse` forwards uploads here from the server (not the browser).
# Vercel: Project → Settings → Environment Variables → add for Production (and Preview if needed).
#
# Example: https://your-parser.onrender.com
STATEMENT_PARSER_URL=

# Optional: long parses need enough serverless duration. This repo sets maxDuration=120 on
# `app/api/parse/route.js`. Vercel Hobby limits functions to 10s; Pro supports higher limits.
